<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>all history - money diary</title>
    <link rel="stylesheet" href="../assets/css/sanitize.css">
    <link rel="stylesheet" href="../assets/css/base.css">
</head>
<body>
    <header>
        <h1>Full History</h1>
    </header>
    <main>
        <div style="margin-bottom: 1rem;">
            <a href="../index.html" class="button button-secondary">&larr; Back to Entry</a>
        </div>

        <div style="overflow-x: auto;">
            <table id="history">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Category</th>
                        <th>Amount</th>
                        <th>Note</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody id="full-history-list"></tbody>
            </table>
        </div>
    </main>
    <footer>
        <p style="text-align: center; color: #777; margin: 2rem 0;">&copy; 2026 money diary</p>
    </footer>
    <script type="module" src="../assets/js/datatable.js"></script>
</body>
</html>
